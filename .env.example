# CPITracker — Environment Variables
# Copy to .env and fill in your keys.

# Helius RPC — used for transaction fetching and simulation
HELIUS_API_KEY=
RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
DEVNET_RPC_URL=https://devnet.helius-rpc.com/?api-key=YOUR_KEY

# Server
PORT=3001

# Optional — Claude API for error explanation
ANTHROPIC_API_KEY=
